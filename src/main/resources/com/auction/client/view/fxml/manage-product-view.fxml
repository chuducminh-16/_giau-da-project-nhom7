<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="737" prefWidth="1187" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ManageProductController">
   <children>

      <!-- Navbar -->
      <HBox alignment="CENTER_LEFT" prefHeight="56" prefWidth="1187" spacing="0"
            style="-fx-background-color: #1a1f2e; -fx-padding: 0 24 0 24;"
            AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"
                   text="🔨 THE CURATOR  —  Seller Dashboard" />
         </children>
      </HBox>

      <!-- SplitPane -->
      <SplitPane dividerPositions="0.46" style="-fx-background-color: #f0f2f5;"
                 AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                 AnchorPane.rightAnchor="0" AnchorPane.topAnchor="56">
         <items>

            <!-- ══════════════════════════════════════
                 CỘT TRÁI: Form nhập liệu sản phẩm
            ══════════════════════════════════════ -->
            <AnchorPane minHeight="0" minWidth="0" style="-fx-background-color: #f0f2f5;">
               <children>
                  <VBox spacing="0"
                        style="-fx-background-color: white; -fx-padding: 24 36 24 36;
                               -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,0);"
                        AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                        AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                     <children>

                        <Label style="-fx-text-fill: #1a1f2e; -fx-font-size: 18;
                                      -fx-font-weight: bold; -fx-padding: 0 0 16 0;"
                               text="INFORMATION" />

                        <!-- Tên sản phẩm -->
                        <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="0">
                           <children>
                              <Label prefWidth="130" style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Tên sản phẩm:" />
                              <TextField fx:id="txtName" prefHeight="36"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 10;"
                                         HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>

                        <!-- Giá khởi điểm -->
                        <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="0">
                           <children>
                              <Label prefWidth="130" style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Giá khởi điểm:" />
                              <TextField fx:id="txtStartingPrice" prefHeight="36"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 10;"
                                         HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>

                        <!-- Bước giá -->
                        <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="0">
                           <children>
                              <Label prefWidth="130" style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Bước giá:" />
                              <TextField fx:id="txtBidIncrement" prefHeight="36"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 10;"
                                         HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>

                        <!-- Mô tả -->
                        <HBox alignment="TOP_LEFT" prefHeight="90" spacing="0">
                           <VBox.margin><Insets bottom="6" /></VBox.margin>
                           <children>
                              <Label prefHeight="36" prefWidth="130"
                                     style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Mô tả:" />
                              <TextArea fx:id="txtDescription" prefHeight="90"
                                        style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                               -fx-border-radius: 6; -fx-background-radius: 6;"
                                        HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>

                        <!-- Loại sản phẩm -->
                        <Label style="-fx-text-fill: #2d3748; -fx-font-size: 12;
                                      -fx-font-weight: bold; -fx-padding: 6 0 6 0;"
                               text="📦 Loại sản phẩm" />
                        <HBox alignment="CENTER_LEFT" prefHeight="44" spacing="10">
                           <VBox.margin><Insets bottom="4" /></VBox.margin>
                           <children>
                              <Button fx:id="btnTypeArt" mnemonicParsing="false"
                                      onAction="#onTypeArtClick" prefHeight="36" prefWidth="120"
                                      style="-fx-background-color: #4299e1; -fx-text-fill: white;
                                             -fx-background-radius: 8; -fx-cursor: hand;
                                             -fx-font-size: 13; -fx-font-weight: bold; -fx-border-radius: 8;"
                                      text="🎨 Art" />
                              <Button fx:id="btnTypeElectronics" mnemonicParsing="false"
                                      onAction="#onTypeElectronicsClick" prefHeight="36" prefWidth="160"
                                      style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568;
                                             -fx-background-radius: 8; -fx-cursor: hand;
                                             -fx-font-size: 13; -fx-font-weight: bold; -fx-border-radius: 8;"
                                      text="💻 Electronics" />
                              <Button fx:id="btnTypeVehicle" mnemonicParsing="false"
                                      onAction="#onTypeVehicleClick" prefHeight="36" prefWidth="130"
                                      style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568;
                                             -fx-background-radius: 8; -fx-cursor: hand;
                                             -fx-font-size: 13; -fx-font-weight: bold; -fx-border-radius: 8;"
                                      text="🚗 Vehicle" />
                           </children>
                        </HBox>

                        <!-- Thời gian bắt đầu -->
                        <Label style="-fx-text-fill: #2d3748; -fx-font-size: 12;
                                      -fx-font-weight: bold; -fx-padding: 6 0 4 0;"
                               text="⏰ Thời gian bắt đầu" />
                        <HBox alignment="CENTER_LEFT" prefHeight="44" spacing="8">
                           <children>
                              <Label prefHeight="19.0" prefWidth="86.0"
                                     style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Ngày:" />
                              <DatePicker fx:id="dpStartDate" prefHeight="36" prefWidth="160.0"
                                          style="-fx-background-radius: 6;" />
                              <Label style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Giờ:" />
                              <TextField fx:id="txtStartHour" prefHeight="36" prefWidth="46" promptText="HH"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6;
                                                -fx-alignment: CENTER; -fx-padding: 0 6;" />
                              <Label style="-fx-text-fill: #718096; -fx-font-weight: bold;" text=":" />
                              <TextField fx:id="txtStartMinute" prefHeight="36" prefWidth="46" promptText="MM"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6;
                                                -fx-alignment: CENTER; -fx-padding: 0 6;" />
                              <Label style="-fx-text-fill: #718096; -fx-font-weight: bold;" text=":" />
                              <TextField fx:id="txtStartSecond" prefHeight="36" prefWidth="46" promptText="SS"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6;
                                                -fx-alignment: CENTER; -fx-padding: 0 6;" />
                           </children>
                        </HBox>

                        <!-- Thời gian kết thúc -->
                        <Label style="-fx-text-fill: #2d3748; -fx-font-size: 12;
                                      -fx-font-weight: bold; -fx-padding: 6 0 4 0;"
                               text="🏁 Thời gian kết thúc" />
                        <HBox alignment="CENTER_LEFT" prefHeight="44" spacing="8">
                           <children>
                              <Label prefHeight="19.0" prefWidth="87.0"
                                     style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Ngày:" />
                              <DatePicker fx:id="dateEnd" prefHeight="36" prefWidth="160"
                                          style="-fx-background-radius: 6;" />
                              <Label style="-fx-text-fill: #4a5568; -fx-font-size: 13;" text="Giờ:" />
                              <TextField fx:id="txtEndHour" prefHeight="36" prefWidth="46" promptText="HH"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6;
                                                -fx-alignment: CENTER; -fx-padding: 0 6;" />
                              <Label style="-fx-text-fill: #718096; -fx-font-weight: bold;" text=":" />
                              <TextField fx:id="txtEndMinute" prefHeight="36" prefWidth="46" promptText="MM"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6;
                                                -fx-alignment: CENTER; -fx-padding: 0 6;" />
                              <Label style="-fx-text-fill: #718096; -fx-font-weight: bold;" text=":" />
                              <TextField fx:id="txtEndSecond" prefHeight="36" prefWidth="46" promptText="SS"
                                         style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6; -fx-background-radius: 6;
                                                -fx-alignment: CENTER; -fx-padding: 0 6;" />
                           </children>
                        </HBox>

                        <!-- Upload hình ảnh -->
                        <Label prefHeight="29.0" prefWidth="141.0"
                               style="-fx-text-fill: #2d3748; -fx-font-size: 12;
                                      -fx-font-weight: bold; -fx-padding: 8 0 4 0;"
                               text="Upload hình ảnh:" />
                        <HBox alignment="CENTER_LEFT" prefHeight="122.0" prefWidth="450.0" spacing="10">
                           <VBox.margin><Insets bottom="4" /></VBox.margin>
                           <children>
                              <VBox alignment="CENTER" prefHeight="122.0" prefWidth="84.0" spacing="4">
                                 <children>
                                    <StackPane prefHeight="80" prefWidth="110"
                                               style="-fx-background-color: #edf2f7; -fx-background-radius: 6;
                                                      -fx-border-color: #cbd5e0; -fx-border-radius: 6;">
                                       <children>
                                          <ImageView fx:id="imgPreview1" fitHeight="93.0" fitWidth="176.0"
                                                     pickOnBounds="true" preserveRatio="true" />
                                       </children>
                                    </StackPane>
                                    <Button mnemonicParsing="false" onAction="#onSelectImage1Click"
                                            prefHeight="26" prefWidth="110"
                                            style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568;
                                                   -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 11;"
                                            text="Up" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER" spacing="4" />
                              <VBox alignment="CENTER" spacing="4" />
                              <VBox alignment="CENTER" spacing="4" />
                           </children>
                        </HBox>

                        <!-- Nút hành động Add / Update -->
                        <HBox alignment="CENTER_LEFT" prefHeight="52" spacing="16">
                           <children>
                              <Button mnemonicParsing="false" onAction="#onAddProductClick"
                                      prefHeight="40" prefWidth="134"
                                      style="-fx-background-color: #4299e1; -fx-text-fill: white;
                                             -fx-background-radius: 6; -fx-cursor: hand;
                                             -fx-font-weight: bold; -fx-font-size: 12;"
                                      text="Add Product" />
                              <Button fx:id="btnUpdate" mnemonicParsing="false"
                                      onAction="#handleUpdateProduct"
                                      prefHeight="40" prefWidth="130"
                                      style="-fx-background-color: #38a169; -fx-text-fill: white;
                                             -fx-background-radius: 6; -fx-cursor: hand;
                                             -fx-font-weight: bold; -fx-font-size: 12;"
                                      text="Update">
                                 <HBox.margin><Insets left="40" /></HBox.margin>
                              </Button>
                           </children>
                        </HBox>

                     </children>
                  </VBox>
               </children>
            </AnchorPane>

            <!-- ══════════════════════════════════════
                 CỘT PHẢI: Bảng danh sách sản phẩm
            ══════════════════════════════════════ -->
            <AnchorPane minHeight="0" minWidth="0" style="-fx-background-color: #f0f2f5;">
               <children>
                  <VBox spacing="0"
                        style="-fx-background-color: #f0f2f5; -fx-padding: 24 20 20 20;"
                        AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                        AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                     <children>
                        <Label style="-fx-text-fill: #1a1f2e; -fx-font-size: 18;
                                      -fx-font-weight: bold; -fx-padding: 0 0 16 0;"
                               text="LIST PRODUCTS" />

                        <TableView fx:id="tableProducts" prefHeight="529.0" prefWidth="597.0"
                                   style="-fx-background-color: white; -fx-background-radius: 10;
                                          -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);"
                                   VBox.vgrow="ALWAYS">
                           <VBox.margin><Insets bottom="16" /></VBox.margin>
                           <columns>
                              <TableColumn fx:id="colName"       prefWidth="140" text="Tên sản phẩm" />
                              <TableColumn fx:id="colPrice"      prefWidth="110" text="Giá khởi điểm" />
                              <TableColumn fx:id="colTime"       prefWidth="150" text="Kết thúc" />
                              <TableColumn fx:id="colStatus"     prefWidth="90"  text="Trạng thái" />
                              <TableColumn fx:id="colCurrentBid" prefWidth="110" text="Giá hiện tại" />
                           </columns>
                        </TableView>

                        <!-- Nút Delete + Back Home + statusLabel -->
                        <HBox alignment="CENTER_LEFT" prefHeight="60" prefWidth="597.0" spacing="12">
                           <children>
                              <Button mnemonicParsing="false" onAction="#onDeleteClick"
                                      prefHeight="42" prefWidth="110"
                                      style="-fx-background-color: #e53e3e; -fx-text-fill: white;
                                             -fx-background-radius: 6; -fx-cursor: hand;
                                             -fx-font-weight: bold; -fx-font-size: 12;"
                                      text="🗑 Delete" />
                              <Button mnemonicParsing="false" onAction="#onBackHomeClick"
                                      prefHeight="42" prefWidth="120"
                                      style="-fx-background-color: #2d3748; -fx-text-fill: #a0aec0;
                                             -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12;"
                                      text="← Back Home">
                                 <HBox.margin><Insets left="40" /></HBox.margin>
                              </Button>

                              <!-- ✅ statusLabel hiện cạnh Back Home, tự đổi màu xanh/đỏ -->
                              <Label fx:id="statusLabel"
                                     text=""
                                     visible="true"
                                     managed="true"
                                     wrapText="true"
                                     style="-fx-font-size: 12px; -fx-font-weight: bold;">
                                 <HBox.margin><Insets left="12" /></HBox.margin>
                              </Label>
                           </children>
                        </HBox>

                     </children>
                  </VBox>
               </children>
            </AnchorPane>

         </items>
      </SplitPane>
   </children>
</AnchorPane>
