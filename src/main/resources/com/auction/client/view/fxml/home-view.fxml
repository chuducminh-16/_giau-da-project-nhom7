<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.HomeController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

         <!-- ══════════════════════════════════════════
              NAVBAR
         ══════════════════════════════════════════ -->
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="0" style="-fx-background-color: #1a1f2e; -fx-padding: 0 24 0 24;">
               <children>
                  <!-- Logo / Brand -->
                  <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 0 32 0 0;" text="🔨 THE CURATOR" />

                  <!-- Nav links -->
                  <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 13; -fx-padding: 0 20 0 0; -fx-cursor: hand;" text="Auctions" />
                  <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 13; -fx-padding: 0 20 0 0; -fx-cursor: hand;" text="Categories" />
                  <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 13; -fx-padding: 0 20 0 0; -fx-cursor: hand;" text="Private Sales" />

                  <Region HBox.hgrow="ALWAYS" />

                  <!-- Search -->
                  <TextField fx:id="searchField" onKeyPressed="#onSearchEnter" prefHeight="34" prefWidth="200" promptText="🔍  Search lots, artists..." style="-fx-background-color: #2d3748; -fx-text-fill: white;                                     -fx-prompt-text-fill: #718096; -fx-background-radius: 6;                                     -fx-border-radius: 6; -fx-padding: 0 10;" />

                  <!-- ACC button -->
                  <Button mnemonicParsing="false" style="-fx-background-color: #2d3748; -fx-text-fill: #a0aec0;                                  -fx-background-radius: 6; -fx-cursor: hand;                                  -fx-padding: 6 14; -fx-font-size: 12;" text="👤 ACC">
                     <HBox.margin><Insets left="12" /></HBox.margin>
                  </Button>

                  <!-- Logout — giữ nguyên onAction -->
                  <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#onLogoutClick" style="-fx-background-color: #e53e3e; -fx-text-fill: white;                                  -fx-background-radius: 6; -fx-cursor: hand;                                  -fx-padding: 6 16; -fx-font-size: 12; -fx-font-weight: bold;" text="Đăng xuất">
                     <HBox.margin><Insets left="12" /></HBox.margin>
                  </Button>
               </children>
            </HBox>
         </top>

         <!-- ══════════════════════════════════════════
              BODY = SIDEBAR + CONTENT
         ══════════════════════════════════════════ -->
         <center>
            <HBox>

               <!-- ── SIDEBAR — giống auctionlist-view ── -->
               <VBox prefWidth="210" spacing="4" style="-fx-background-color: #1a1f2e; -fx-padding: 20 12 20 12;">
                  <children>
                     <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                    -fx-font-weight: bold; -fx-padding: 0 0 8 8;" text="MENU" />

                     <!-- Danh sách đấu giá (active tab) -->
                     <Button fx:id="btnSideAuctions" maxWidth="Infinity" mnemonicParsing="false" onAction="#onSideAuctionsClick" style="-fx-background-color: #4299e1; -fx-text-fill: white;                                     -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;                                     -fx-padding: 10 14; -fx-font-size: 13; -fx-cursor: hand;" text="📋  Danh sách đấu giá" />

                     <!-- Đăng sản phẩm — giữ nguyên onAction onSellerDashboardClick -->
                     <Button fx:id="btnSellerDash" maxWidth="Infinity" mnemonicParsing="false" onAction="#onSellerDashboardClick" style="-fx-background-color: transparent; -fx-text-fill: #a0aec0;                                     -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;                                     -fx-padding: 10 14; -fx-font-size: 13; -fx-cursor: hand;" text="➕  Đăng sản phẩm">
                        <VBox.margin><Insets top="2" /></VBox.margin>
                     </Button>

                     <!-- Lịch sử đấu giá -->
                     <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onBidHistoryClick" style="-fx-background-color: transparent; -fx-text-fill: #a0aec0;                                     -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;                                     -fx-padding: 10 14; -fx-font-size: 13; -fx-cursor: hand;" text="📊  Lịch sử đấu giá">
                        <VBox.margin><Insets top="2" /></VBox.margin>
                     </Button>

                     <Region VBox.vgrow="ALWAYS" />

                     <!-- Divider -->
                     <Label style="-fx-text-fill: #2d3748; -fx-padding: 8 0;" text="──────────────" />

                     <!-- User info bottom -->
                     <Label fx:id="userLabel" style="-fx-text-fill: #718096; -fx-font-size: 11; -fx-padding: 0 0 0 8;" text="👤  Người dùng" />
                  </children>
               </VBox>

               <!-- ── CONTENT AREA ── -->
               <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #f0f2f5; -fx-background: #f0f2f5;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                  <content>
                     <VBox spacing="28" style="-fx-background-color: #f0f2f5; -fx-padding: 28 32 40 32;">
                        <children>

                           <!-- ─────────────────────────────────────
                                HERO CARD — "Live now" nổi bật
                           ───────────────────────────────────── -->
                           <HBox spacing="0" style="-fx-background-color: #1a1f2e;                                         -fx-background-radius: 12;                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.18),12,0,0,4);">
                              <children>
                                 <!-- Placeholder ảnh hero -->
                                 <StackPane prefHeight="240" prefWidth="340" style="-fx-background-color: #2d3748;                                                    -fx-background-radius: 12 0 0 12;">
                                    <children>
                                       <ImageView fitHeight="240" fitWidth="340" pickOnBounds="true" preserveRatio="true" />
                                       <Label style="-fx-font-size: 48; -fx-text-fill: #4a5568;" text="📷" />
                                    </children>
                                 </StackPane>

                                 <!-- Thông tin hero -->
                                 <VBox spacing="12" style="-fx-padding: 30 32 30 32;" HBox.hgrow="ALWAYS">
                                    <children>
                                       <!-- Badge Live now + Lot -->
                                       <HBox alignment="CENTER_LEFT" spacing="10">
                                          <children>
                                             <Label style="-fx-text-fill: #fc8181;                                                            -fx-font-size: 11; -fx-font-weight: bold;                                                            -fx-background-color: #742a2a;                                                            -fx-background-radius: 20;                                                            -fx-padding: 3 10;" text="🔴  LIVE NOW" />
                                             <Label fx:id="heroStatus"
                                                    text="Lot 001"
                                                    style="-fx-text-fill: #a0aec0; -fx-font-size: 12;" />
                                          </children>
                                       </HBox>

                                       <!-- Tên sản phẩm — thêm fx:id -->
                                       <Label fx:id="heroName"
                                              text="Đang tải..."
                                              wrapText="true"
                                              style="-fx-text-fill: white; -fx-font-size: 24;
              -fx-font-weight: bold;" />

                                       <!-- Mô tả -->
                                       <Label fx:id="heroDesc"
                                              text=""
                                              wrapText="true"
                                              style="-fx-text-fill: #718096; -fx-font-size: 13;" />

                                       <Region VBox.vgrow="ALWAYS" />

                                       <!-- Divider -->
                                       <Label style="-fx-text-fill: #2d3748;" text="──────────────────────────────────────────" />

                                       <!-- Giá + nút Place Bid -->
                                       <HBox alignment="CENTER_LEFT" spacing="20">
                                          <children>
                                             <VBox spacing="2">
                                                <children>
                                                   <Label style="-fx-text-fill: #a0aec0;                                                                  -fx-font-size: 10;                                                                  -fx-font-weight: bold;" text="CURRENT BID" />
                                                   <Label fx:id="heroBid"
                                                          text="--"
                                                          style="-fx-text-fill: #68d391;
              -fx-font-size: 26;
              -fx-font-weight: bold;" />
                                                </children>
                                             </VBox>
                                             <Region HBox.hgrow="ALWAYS" />
                                             <!-- Place Bid → detail-view (giữ nguyên) -->
                                             <Button mnemonicParsing="false" onAction="#onHeroBidClicked" prefHeight="44" prefWidth="150" style="-fx-background-color: #4299e1;                                                             -fx-text-fill: white;                                                             -fx-font-size: 14; -fx-font-weight: bold;                                                             -fx-background-radius: 8;                                                             -fx-cursor: hand;" text="Place Bid  →" />
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                           <!-- /CURATED LOTS -->

                           <!-- ─────────────────────────────────────
                                BẢNG PHIÊN ĐẤU GIÁ — style auctionlist
                                Nút "Tham gia" → detail-view
                           ───────────────────────────────────── -->
                           <VBox spacing="12" style="-fx-background-color: white;                                         -fx-background-radius: 10;                                         -fx-padding: 20;                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                              <children>
                                 <!-- Header -->
                                 <HBox alignment="CENTER_LEFT" spacing="12">
                                    <children>
                                       <Label style="-fx-font-size: 16; -fx-font-weight: bold;                                                      -fx-text-fill: #2d3748;" text="Phiên đấu giá đang diễn ra" />
                                       <Region HBox.hgrow="ALWAYS" />
                                       <Button mnemonicParsing="false" onAction="#onRefreshAuctions" style="-fx-background-color: #edf2f7;                                                       -fx-text-fill: #4a5568;                                                       -fx-background-radius: 6;                                                       -fx-cursor: hand; -fx-padding: 6 14;" text="🔄 Làm mới" />
                                    </children>
                                 </HBox>

                                 <!-- TableView -->
                                 <TableView fx:id="auctionTable" prefHeight="260" style="-fx-background-color: white;                                                    -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                    <columns>
                                       <TableColumn fx:id="colAuctionName" prefWidth="260" text="Sản phẩm" />
                                       <TableColumn fx:id="colAuctionPrice" prefWidth="140" text="Giá hiện tại" />
                                       <TableColumn fx:id="colAuctionTime" prefWidth="130" text="Còn lại" />
                                       <TableColumn fx:id="colAuctionStatus" prefWidth="130" text="Trạng thái" />
                                       <TableColumn fx:id="colAuctionAction" prefWidth="120" text="Hành động" />
                                    </columns>
                                 </TableView>
                              </children>
                           </VBox>
                           <!-- /BẢNG PHIÊN ĐẤU GIÁ -->

                        </children>
                     </VBox>
                  </content>
               </ScrollPane>
               <!-- /CONTENT AREA -->

            </HBox>
         </center>

      </BorderPane>
   </children>
</AnchorPane>
