<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
   <children>
      <StackPane fx:id="rootPane" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
         <children>

            <!-- Ảnh nền — giữ nguyên fx:id -->
            <ImageView fx:id="backgroundImage" fitHeight="1091" fitWidth="1931" pickOnBounds="true" StackPane.alignment="CENTER">
               <image>
                  <Image url="@../images/login-pic.png" />
               </image>
            </ImageView>

            <!-- Overlay tối mờ để form nổi bật -->
            <StackPane style="-fx-background-color: rgba(10,14,26,0.55);" />

            <!-- Form card căn giữa bên phải -->
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 120 0 0;">
               <children>
                  <VBox alignment="CENTER" prefHeight="1091.0" prefWidth="391.0" spacing="18" style="-fx-background-color: rgba(26,31,46,0.96);                                -fx-background-radius: 16;                                -fx-padding: 48 44 48 44;                                -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.5),24,0,0,8);">
                     <children>

                        <!-- Brand -->
                        <Label style="-fx-text-fill: white; -fx-font-size: 20;                                       -fx-font-weight: bold; -fx-padding: 0 0 8 0;" text="🔨 THE CURATOR" />

                        <!-- Tiêu đề -->
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 14;" text="Log In" />

                        <!-- Divider -->
                        <Label style="-fx-text-fill: #2d3748;" text="──────────────────────────" />

                        <!-- Email — giữ nguyên fx:id -->
                        <VBox spacing="6">
                           <children>
                              <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11;                                             -fx-font-weight: bold;" text="EMAIL" />
                              <TextField fx:id="emailInput" maxWidth="300" prefHeight="40" promptText="your@email.com" style="-fx-background-color: #2d3748;                                                 -fx-text-fill: white;                                                 -fx-prompt-text-fill: #4a5568;                                                 -fx-background-radius: 6;                                                 -fx-border-color: #4a5568;                                                 -fx-border-radius: 6;                                                 -fx-padding: 0 12; -fx-font-size: 13;" />
                           </children>
                        </VBox>

                        <!-- Password — giữ nguyên fx:id -->
                        <VBox spacing="6">
                           <children>
                              <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11;                                             -fx-font-weight: bold;" text="PASSWORD" />
                              <PasswordField fx:id="passwordInput" maxWidth="300" prefHeight="40" promptText="••••••••" style="-fx-background-color: #2d3748;                                                     -fx-text-fill: white;                                                     -fx-prompt-text-fill: #4a5568;                                                     -fx-background-radius: 6;                                                     -fx-border-color: #4a5568;                                                     -fx-border-radius: 6;                                                     -fx-padding: 0 12; -fx-font-size: 13;" />
                           </children>
                        </VBox>

                        <Label fx:id="errorLabel"
                               visible="false"
                               managed="false"
                               maxWidth="300"
                               wrapText="true"
                               style="-fx-text-fill: #fc8181; -fx-font-size: 12px;"/>

                        <!-- Nút Sign In — giữ nguyên fx:id, onAction -->
                        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#onLoginClicked" prefHeight="44" prefWidth="300" style="-fx-background-color: #4299e1; -fx-text-fill: white;                                        -fx-font-size: 14; -fx-font-weight: bold;                                        -fx-background-radius: 8; -fx-cursor: hand;" text="Sign In">
                           <VBox.margin><Insets top="8" /></VBox.margin>
                        </Button>

                        <!-- Nút Sign Up — giữ nguyên fx:id, onAction -->
                        <Button fx:id="btnSignUp" mnemonicParsing="false" onAction="#onSignUpClick" prefHeight="38" prefWidth="300" style="-fx-background-color: transparent;                                        -fx-text-fill: #a0aec0;                                        -fx-border-color: #4a5568; -fx-border-radius: 8;                                        -fx-background-radius: 8;                                        -fx-font-size: 13; -fx-cursor: hand;" text="Sign Up" />

                        <!-- Forgot password -->
                        <Label style="-fx-text-fill: #4299e1; -fx-font-size: 12;                                       -fx-cursor: hand; -fx-underline: true;" text="Forgot your password?" />

                     </children>
                  </VBox>
               </children>
            </HBox>

         </children>
      </StackPane>
   </children>
</AnchorPane>
