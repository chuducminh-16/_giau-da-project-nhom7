<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    PROFILE-VIEW (Register) — Redesign theo theme home-view
    Giữ nguyên: fx:id tất cả field, onAction (#onRegisterClick, #onBackToLoginClick)
                vị trí logic: left = ảnh brand, right = form đăng ký
    Controller: ProfileController
-->

<AnchorPane style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ProfileController">
   <children>

      <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

         <!-- ══ TOP NAVBAR ══ -->
         <top>
            <BorderPane prefHeight="60" prefWidth="1282" style="-fx-background-color: #1a1f2e; -fx-padding: 0 30 0 30;" BorderPane.alignment="CENTER">
               <left>
                  <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="🔨 CURATOR" BorderPane.alignment="CENTER" />
               </left>
               <right>
                  <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 13; -fx-cursor: hand;" text="SUPPORT" BorderPane.alignment="CENTER" />
               </right>
            </BorderPane>
         </top>

         <!-- ══ BOTTOM FOOTER ══ -->
         <bottom>
            <BorderPane prefHeight="56" prefWidth="1282" style="-fx-background-color: #1a1f2e; -fx-padding: 0 30 0 30;" BorderPane.alignment="CENTER">
               <left>
                  <Label style="-fx-text-fill: #4a5568; -fx-font-size: 13; -fx-font-weight: bold;" text="🔨 CURATOR" BorderPane.alignment="TOP_LEFT" />
               </left>
               <right>
                  <Label style="-fx-text-fill: #4a5568; -fx-font-size: 11;" text="© 2024 THE CURATOR AUCTION HOUSE" BorderPane.alignment="TOP_RIGHT" />
               </right>
            </BorderPane>
         </bottom>

         <!-- ══ CENTER: Brand card (trái) + Form đăng ký (phải) ══ -->
         <center>
            <HBox alignment="CENTER" spacing="0" style="-fx-background-color: #f0f2f5; -fx-padding: 40 80 40 80;" BorderPane.alignment="CENTER">
               <children>

                  <!-- ── Cột trái: Brand image card ── -->
                  <StackPane prefHeight="580" prefWidth="380">
                     <children>
                        <!-- Ảnh brand — giữ nguyên url -->
                        <ImageView fitHeight="580" fitWidth="380" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(gaussian,rgba(0,0,0,0.25),16,0,0,6);">
                           <image>
                              <Image url="@../images/profile-pic.png" />
                           </image>
                        </ImageView>
                        <!-- Overlay text -->
                        <VBox prefHeight="580" prefWidth="340" spacing="16" style="-fx-background-color: rgba(10,14,26,0.55);                                      -fx-padding: 40 36 40 36;">
                           <children>
                              <Label prefWidth="300" style="-fx-text-fill: white; -fx-font-size: 22;                                             -fx-font-weight: bold;" text="JOIN THE COLLECTION" wrapText="true" />
                              <Label prefWidth="300" style="-fx-text-fill: #a0aec0; -fx-font-size: 13;" text="Gain exclusive access..." wrapText="true" />
                              <Region VBox.vgrow="ALWAYS" />
                              <Label style="-fx-text-fill: #718096; -fx-font-size: 12;" text="__EST. 2024__" />
                           </children>
                        </VBox>
                     </children>
                  </StackPane>

                  <!-- ── Cột phải: Form đăng ký ── -->
                  <VBox prefHeight="580" prefWidth="480" spacing="14" style="-fx-background-color: white;                                -fx-background-radius: 0 16 16 0;                                -fx-padding: 40 44 40 44;                                -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.1),12,0,0,4);">
                     <children>

                        <!-- Tiêu đề -->
                        <Label style="-fx-text-fill: #1a1f2e; -fx-font-size: 20;                                       -fx-font-weight: bold;" text="CREATE ACCOUNT" />
                        <Label prefWidth="380" style="-fx-text-fill: #718096; -fx-font-size: 12;" text="Enter your details to register for the upcoming auctions" wrapText="true" />

                        <!-- Full Name + Username -->
                        <HBox prefHeight="68" prefWidth="392" spacing="16">
                           <children>
                              <VBox spacing="4" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                                   -fx-font-weight: bold;" text="FULL NAME" />
                                    <TextField fx:id="fullNameField" prefHeight="36" style="-fx-background-color: #f7fafc;                                                       -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                       -fx-background-radius: 6; -fx-padding: 0 10;" />
                                 </children>
                              </VBox>
                              <VBox spacing="4" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                                   -fx-font-weight: bold;" text="USERNAME" />
                                    <TextField fx:id="usernameField" prefHeight="36" style="-fx-background-color: #f7fafc;                                                       -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                       -fx-background-radius: 6; -fx-padding: 0 10;" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Email -->
                        <VBox spacing="4">
                           <children>
                              <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                             -fx-font-weight: bold;" text="EMAIL ADDRESS" />
                              <TextField fx:id="emailField" prefHeight="36" prefWidth="392" style="-fx-background-color: #f7fafc;                                                 -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                 -fx-background-radius: 6; -fx-padding: 0 10;" />
                           </children>
                        </VBox>

                        <!-- Phone -->
                        <VBox spacing="4">
                           <children>
                              <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                             -fx-font-weight: bold;" text="PHONE NUMBER" />
                              <TextField fx:id="phoneField" prefHeight="36" prefWidth="392" style="-fx-background-color: #f7fafc;                                                 -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                 -fx-background-radius: 6; -fx-padding: 0 10;" />
                           </children>
                        </VBox>

                        <!-- Password + Confirm Password -->
                        <HBox prefHeight="68" prefWidth="392" spacing="16">
                           <children>
                              <VBox spacing="4" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                                   -fx-font-weight: bold;" text="PASSWORD" />
                                    <PasswordField fx:id="passwordField" prefHeight="36" style="-fx-background-color: #f7fafc;                                                           -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                           -fx-background-radius: 6; -fx-padding: 0 10;" />
                                 </children>
                              </VBox>
                              <VBox spacing="4" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                                   -fx-font-weight: bold;" text="CONFIRM PASSWORD" />
                                    <PasswordField fx:id="confirmPasswordField" prefHeight="36" style="-fx-background-color: #f7fafc;                                                           -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                           -fx-background-radius: 6; -fx-padding: 0 10;" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Address -->
                        <VBox spacing="4">
                           <children>
                              <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                                             -fx-font-weight: bold;" text="ADDRESS" />
                              <TextField fx:id="addressField" prefHeight="36" prefWidth="392" style="-fx-background-color: #f7fafc;                                                 -fx-border-color: #e2e8f0; -fx-border-radius: 6;                                                 -fx-background-radius: 6; -fx-padding: 0 10;" />
                           </children>
                        </VBox>
                        <!-- ══ Chọn Role ══ -->
                        <VBox spacing="6">
                           <children>
                              <Label style="-fx-text-fill: #4a5568; -fx-font-size: 10;                               -fx-font-weight: bold;" text="ACCOUNT ROLE" />
                              <HBox alignment="CENTER_LEFT" spacing="20">
                                 <children>
                                    <!-- Bidder — mặc định được chọn, đồng thời khai báo ToggleGroup tại đây -->
                                    <RadioButton fx:id="radioBidder" prefHeight="19.0" prefWidth="116.0" selected="true" style="-fx-font-size: 13; -fx-text-fill: #2d3748; -fx-cursor: hand;" text="Bidder">
                                       <toggleGroup>
                                          <ToggleGroup fx:id="roleToggleGroup" />
                                       </toggleGroup>
                                    </RadioButton>
                                    <!-- Seller — dùng $roleToggleGroup để tham chiếu lại -->
                                    <RadioButton fx:id="radioSeller" prefHeight="19.0" prefWidth="121.0" style="-fx-font-size: 13; -fx-text-fill: #2d3748; -fx-cursor: hand;" text="Seller" toggleGroup="$roleToggleGroup" />
                                    <!-- Admin -->
                                    <RadioButton fx:id="radioAdmin" prefHeight="19.0" prefWidth="95.0" style="-fx-font-size: 13; -fx-text-fill: #2d3748; -fx-cursor: hand;" text="Admin" toggleGroup="$roleToggleGroup" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

