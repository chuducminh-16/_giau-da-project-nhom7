                        <Label fx:id="errorLabel" managed="false" prefWidth="392" style="-fx-font-size: 12px; -fx-padding: 4 0 0 0;" visible="false" wrapText="true" />

                        <!-- Nút REGISTER + Back to login — giữ nguyên fx:id, onAction -->
                        <HBox alignment="CENTER_LEFT" prefHeight="52" spacing="12">
                           <children>
                              <Button fx:id="btnRegister" mnemonicParsing="false" onAction="#onRegisterClick" prefHeight="42" prefWidth="150" style="-fx-background-color: #1a1f2e; -fx-text-fill: white;                                              -fx-font-weight: bold; -fx-font-size: 13;                                              -fx-background-radius: 8; -fx-cursor: hand;" text="REGISTER" />
                              <Button fx:id="btnBackToLogin" mnemonicParsing="false" onAction="#onBackToLoginClick" prefHeight="42" prefWidth="150" style="-fx-background-color: transparent;                                              -fx-text-fill: #4a5568;                                              -fx-border-color: #e2e8f0; -fx-border-radius: 8;                                              -fx-background-radius: 8;                                              -fx-font-size: 12; -fx-cursor: hand;" text="← Back to login" />
                           </children>
                        </HBox>

                        <!-- Disclaimer -->
                        <Label prefWidth="380" style="-fx-text-fill: #a0aec0; -fx-font-size: 11;" text="By registering, you agree..." wrapText="true" />

                     </children>
                  </VBox>

               </children>
            </HBox>
         </center>

      </BorderPane>

   </children>
</AnchorPane>
