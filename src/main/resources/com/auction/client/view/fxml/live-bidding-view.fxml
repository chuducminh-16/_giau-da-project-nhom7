<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.LiveBiddingController">
   <children>
      <BorderPane prefHeight="723" prefWidth="1053"
                  style="-fx-background-color: #f0f2f5;"
                  AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                  AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

         <!-- ══════════════════════════════════════════
              TOP — giữ nguyên: btLeaveRoom, product name, lblCountdown
         ══════════════════════════════════════════ -->
         <top>
            <HBox prefHeight="64" prefWidth="1053" alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color: #1a1f2e; -fx-padding: 0 24 0 16;"
                  BorderPane.alignment="CENTER">
               <children>
                  <!-- Nút LEAVE ROOM — giữ nguyên fx:id, onAction -->
                  <Button fx:id="btLeaveRoom" mnemonicParsing="false"
                          onAction="#onLeaveRoomClick"
                          prefHeight="38" prefWidth="130"
                          text="← LEAVE ROOM"
                          style="-fx-background-color: #e53e3e; -fx-text-fill: white;
                                 -fx-background-radius: 6; -fx-cursor: hand;
                                 -fx-font-size: 12; -fx-font-weight: bold;">
                     <HBox.margin><Insets left="8" /></HBox.margin>
                  </Button>

                  <!-- Tên sản phẩm -->
                  <Label fx:id="lblProductName"
                         text="PRODUCT NAME"
                         HBox.hgrow="ALWAYS"
                         prefHeight="57"
                         prefWidth="461"
                         style="-fx-text-fill: white; -fx-font-size: 16;
              -fx-font-weight: bold; -fx-alignment: CENTER;"/>

                  <!-- Countdown — giữ nguyên fx:id -->
                  <Label fx:id="lblCountdown" text="05:00"
                         prefHeight="57" prefWidth="200"
                         style="-fx-text-fill: #fc8181; -fx-font-size: 22;
                                -fx-font-weight: bold; -fx-alignment: CENTER;">
                     <HBox.margin><Insets right="8" /></HBox.margin>
                  </Label>
               </children>
            </HBox>
         </top>

         <!-- ══════════════════════════════════════════
              CENTER — giữ nguyên: Current Bid, txtBidAmount, Place Bid, priceChart
         ══════════════════════════════════════════ -->
         <center>
            <VBox prefWidth="570" spacing="0"
                  style="-fx-background-color: #f0f2f5; -fx-padding: 24 24 24 24;"
                  BorderPane.alignment="CENTER">
               <children>

                  <!-- Current Bid label -->
                  <Label fx:id="lblCurrentBid"
                         text="Current Bid: --"
                         style="-fx-text-fill: #38a169; -fx-font-size: 22;
              -fx-font-weight: bold; -fx-padding: 0 0 16 0;"/>

                  <!-- Card nhập giá -->
                  <VBox spacing="0"
                        style="-fx-background-color: white; -fx-background-radius: 10;
                               -fx-padding: 20;
                               -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                     <children>
                        <Label text="Đặt giá của bạn"
                               style="-fx-text-fill: #4a5568; -fx-font-size: 13;
                                      -fx-font-weight: bold; -fx-padding: 0 0 10 0;" />
                        <HBox prefHeight="50" spacing="12" alignment="CENTER_LEFT">
                           <children>
                              <!-- txtBidAmount — giữ nguyên fx:id -->
                              <TextField fx:id="txtBidAmount"
                                         prefHeight="44" HBox.hgrow="ALWAYS"
                                         promptText="Nhập số tiền..."
                                         style="-fx-background-color: #f7fafc;
                                                -fx-border-color: #e2e8f0;
                                                -fx-border-radius: 6;
                                                -fx-background-radius: 6;
                                                -fx-font-size: 14; -fx-padding: 0 12;" />
                              <!-- Place Bid — giữ nguyên onAction -->
                              <Button mnemonicParsing="false" onAction="#onPlaceBidClick"
                                      prefHeight="44" prefWidth="130"
                                      text="Place Bid"
                                      style="-fx-background-color: #4299e1;
                                             -fx-text-fill: white; -fx-font-size: 14;
                                             -fx-font-weight: bold; -fx-background-radius: 6;
                                             -fx-cursor: hand;" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- Line Chart — giữ nguyên fx:id: priceChart, xAxis, yAxis -->
                  <LineChart fx:id="priceChart" VBox.vgrow="ALWAYS"
                             animated="false"
                             style="-fx-background-color: white;
                                    -fx-background-radius: 10;
                                    -fx-padding: 10;
                                    -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,2);">
                     <VBox.margin><Insets top="16" /></VBox.margin>
                     <xAxis>
                        <CategoryAxis fx:id="xAxis" side="BOTTOM" label="Thời gian" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis fx:id="yAxis" side="LEFT"
                                    label="Giá (VNĐ)"
                                    forceZeroInRange="false"
                                    autoRanging="true" />
                     </yAxis>
                  </LineChart>

               </children>
            </VBox>
         </center>

         <!-- ══════════════════════════════════════════
              RIGHT — giữ nguyên: tableBidHistory, listNotifications
         ══════════════════════════════════════════ -->
         <right>
            <VBox prefWidth="380" spacing="0"
                  style="-fx-background-color: #f0f2f5; -fx-padding: 24 24 24 0;"
                  BorderPane.alignment="CENTER">
               <children>

                  <!-- Header lịch sử -->
                  <Label text="Lịch sử đặt giá"
                         style="-fx-text-fill: #2d3748; -fx-font-size: 15;
                                -fx-font-weight: bold; -fx-padding: 0 0 10 0;" />

                  <!-- Bảng lịch sử — giữ nguyên fx:id: tableBidHistory, colTime, colUser, colAmount -->
                  <TableView fx:id="tableBidHistory" VBox.vgrow="ALWAYS"
                             style="-fx-background-color: white;
                                    -fx-background-radius: 10;
                                    -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                     <columns>
                        <TableColumn fx:id="colTime"   prefWidth="110" text="Time" />
                        <TableColumn fx:id="colUser"   prefWidth="135" text="User" />
                        <TableColumn fx:id="colAmount" prefWidth="115" text="Amount" />
                     </columns>
                  </TableView>

                  <!-- Thông báo — giữ nguyên fx:id: listNotifications -->
                  <Label text="Thông báo"
                         style="-fx-text-fill: #4a5568; -fx-font-size: 13;
                                -fx-font-weight: bold; -fx-padding: 14 0 8 0;" />
                  <ListView fx:id="listNotifications" prefHeight="130" prefWidth="380"
                            style="-fx-background-color: white;
                                   -fx-background-radius: 10;
                                   -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,2);" />

               </children>
            </VBox>
         </right>

         <padding><Insets top="0" /></padding>
      </BorderPane>
   </children>
</AnchorPane>
