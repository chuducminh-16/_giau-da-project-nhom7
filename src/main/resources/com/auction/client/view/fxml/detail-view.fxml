<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.DetailController">
   <children>

      <!-- Navbar chứa nút BACK — luôn hiển thị trên cùng, không bị đè -->
      <HBox alignment="CENTER_LEFT" prefHeight="56" spacing="0" style="-fx-background-color: #1a1f2e; -fx-padding: 0 24 0 16;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
         <children>
            <!-- Nút BACK — giữ nguyên fx:id, onAction -->
            <Button fx:id="btnBackToHome" mnemonicParsing="false" onAction="#onBackToHomeClick" prefHeight="36" prefWidth="90" style="-fx-background-color: #2d3748; -fx-text-fill: #a0aec0;                            -fx-background-radius: 6; -fx-cursor: hand;                            -fx-font-size: 12; -fx-font-weight: bold;" text="← BACK" />
         </children>
      </HBox>

      <!-- Main content bắt đầu sau navbar (topAnchor=56) -->
      <StackPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="56">
         <children>
            <HBox alignment="CENTER" spacing="0" style="-fx-background-color: #f0f2f5; -fx-padding: 70 60 40 60;">
               <children>

                  <!-- ── Cột trái: ảnh lớn + thumbnails (giữ nguyên fx:id) ── -->
                  <VBox prefHeight="632.0" prefWidth="663.0" spacing="12">
                     <children>
                        <!-- Ảnh chính -->
                        <StackPane prefHeight="432.0" prefWidth="512.0" style="-fx-background-color: #2d3748;                                           -fx-background-radius: 12;                                           -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.18),12,0,0,4);">
                           <children>
                              <ImageView fx:id="mainImageView" fitHeight="434.0" fitWidth="662.0" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </StackPane>

                        <!-- Thumbnails — giữ nguyên fx:id và onMouseClicked -->
                        <HBox alignment="CENTER" prefHeight="186.0" prefWidth="663.0" spacing="30.0">
                           <children>
                              <StackPane prefHeight="100" prefWidth="130" style="-fx-background-color: #2d3748;                                                 -fx-background-radius: 8; -fx-cursor: hand;">
                                 <children>
                                    <ImageView fx:id="thumb1" fitHeight="139.0" fitWidth="183.0" onMouseClicked="#onThumbnailClick" pickOnBounds="true" preserveRatio="true" />
                                 </children>
                              </StackPane>
                              <StackPane prefHeight="100" prefWidth="130" style="-fx-background-color: #2d3748;                                                 -fx-background-radius: 8; -fx-cursor: hand;">
                                 <children>
                                    <ImageView fx:id="thumb2" fitHeight="141.0" fitWidth="175.0" onMouseClicked="#onThumbnailClick" pickOnBounds="true" preserveRatio="true" />
                                 </children>
                              </StackPane>
                              <StackPane prefHeight="139.0" prefWidth="180.0" style="-fx-background-color: #2d3748;                                                 -fx-background-radius: 8; -fx-cursor: hand;">
                                 <children>
                                    <ImageView fx:id="thumb3" fitHeight="141.0" fitWidth="180.0" onMouseClicked="#onThumbnailClick" pickOnBounds="true" preserveRatio="true" />
                                 </children>
                              </StackPane>
                           </children>
                           <padding>
                              <Insets top="40.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- ── Cột phải: thông tin sản phẩm (giữ nguyên fx:id) ── -->
                  <VBox prefHeight="632.0" prefWidth="542.0" spacing="16" style="-fx-padding: 0 0 0 48;" HBox.hgrow="ALWAYS">
                     <children>

                        <!-- Tên sản phẩm -->
                        <Label fx:id="productNameLabel" prefWidth="500" style="-fx-text-fill: #1a1f2e; -fx-font-size: 28;                                       -fx-font-weight: bold;" text="PRODUCT NAME" wrapText="true" />

                        <!-- Giá hiện tại -->
                        <Label fx:id="currentPriceLabel" style="-fx-text-fill: #38a169; -fx-font-size: 20;                                       -fx-font-weight: bold;" text="Current Bid: $0" />

                        <!-- Describe label -->
                        <Label style="-fx-text-fill: #4a5568; -fx-font-size: 15;                                       -fx-font-weight: bold;" text="Describe:">
                           <font><Font size="15" /></font>
                        </Label>

                        <!-- Mô tả sản phẩm — hiện dữ liệu từ server -->
                        <ScrollPane fitToWidth="true" prefHeight="110" prefWidth="500" style="-fx-background-color: white;                    -fx-background-radius: 8;                    -fx-border-color: #e2e8f0;                    -fx-border-radius: 8;">
                           <content>
                              <Label fx:id="lblDescription" alignment="TOP_LEFT" contentDisplay="CENTER" prefHeight="127.0" prefWidth="650.0" style="-fx-text-fill: #4a5568; -fx-font-size: 13;                     -fx-padding: 8; -fx-background-color: white;" wrapText="true" />
                           </content>
                        </ScrollPane>

                        <!-- Divider -->
                        <Label style="-fx-text-fill: #cbd5e0;" text="──────────────────────────────────────────" />

                        <!-- GridPane thông tin chi tiết — giữ nguyên toàn bộ nội dung -->
                        <GridPane prefWidth="489.0" style="-fx-background-color: white;                                          -fx-background-radius: 10;                                          -fx-padding: 16;                                          -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,2);">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="160" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="280" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10" prefHeight="36" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10" prefHeight="36" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10" prefHeight="36" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10" prefHeight="36" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10" prefHeight="36" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10" prefHeight="36" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <children>
                              <!-- Labels cột trái -->
                              <Label prefHeight="19.0" prefWidth="174.0" style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Giá khởi điểm:">
                                 <font><Font size="13" /></font>
                              </Label>
                              <Label prefHeight="19.0" prefWidth="189.0" style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Bước giá:" GridPane.rowIndex="1">
                                 <font><Font size="13" /></font>
                              </Label>
                              <Label prefHeight="19.0" prefWidth="235.0" style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Tình trạng:" GridPane.rowIndex="2">
                                 <font><Font size="13" /></font>
                              </Label>
                              <Label prefHeight="19.0" prefWidth="190.0" style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Danh mục hàng:" GridPane.rowIndex="3">
                                 <font><Font size="13" /></font>
                              </Label>
                              <Label prefHeight="19.0" prefWidth="215.0" style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Xuất xứ:" GridPane.rowIndex="4">
                                 <font><Font size="13" /></font>
                              </Label>
                              <Label prefHeight="19.0" prefWidth="209.0" style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Người bán:" GridPane.rowIndex="5">
                                 <font><Font size="13" /></font>
                              </Label>

                              <!-- Labels cột phải (giá trị) -->
                              <Label fx:id="lblStartingPrice" style="-fx-text-fill: #2d3748; -fx-font-weight: bold;" text="—" GridPane.columnIndex="1" />

                              <Label fx:id="lblBidIncrement" style="-fx-text-fill: #2d3748; -fx-font-weight: bold;" text="—" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                              <Label fx:id="lblStatus" style="-fx-text-fill: #2d3748; -fx-font-weight: bold;" text="—" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                              <Label fx:id="lblCategory" style="-fx-text-fill: #2d3748; -fx-font-weight: bold;" text="—" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                              <Label fx:id="lblOrigin" style="-fx-text-fill: #2d3748; -fx-font-weight: bold;" text="—" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                              <Label fx:id="lblSeller" style="-fx-text-fill: #2d3748; -fx-font-weight: bold;" text="—" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                           </children>
                        </GridPane>

                        <!-- Nút Join Bidding Room — giữ nguyên fx:id và onAction -->
                        <HBox alignment="CENTER" prefHeight="70">
                           <children>
                              <Button fx:id="btnJoinRoom" mnemonicParsing="false" onAction="#onJoinRoomClick" prefHeight="54" prefWidth="500" style="-fx-background-color: #1a1f2e;                                              -fx-text-fill: white;                                              -fx-font-size: 16; -fx-font-weight: bold;                                              -fx-background-radius: 10;                                              -fx-cursor: hand;" text="🔴  Join Bidding Room" />
                           </children>
                        </HBox>

                     </children>
                  </VBox>

               </children>
            </HBox>
         </children>
      </StackPane>

   </children>
</AnchorPane>
