<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="565.0" prefWidth="776.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />
    <Button onAction="#onHelloButtonClick" prefHeight="447.0" prefWidth="503.0" text="Hello!" textAlignment="JUSTIFY" textFill="#132a83">
      <font>
         <Font name="System Bold" size="80.0" />
      </font></Button>
   <Button fx:id="button_ugood" mnemonicParsing="false" onAction="#onUGoodButtonClick" text="u good ?" textAlignment="JUSTIFY" />
</VBox>
