<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="672.0" prefWidth="1053.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="250.0" layoutY="72.0" prefHeight="600.0" prefWidth="800.0" spacing="20.0" styleClass="root" stylesheets="@com/auction/client/css/style.css">
         <children>
            <Label styleClass="heading-1" text="Log In" />
            <TextField fx:id="emailInput" maxWidth="300.0" styleClass="input-field" text="Email" />
            <PasswordField fx:id="passwordInput" maxWidth="300.0" styleClass="input-field" text="Password" />
            <Button fx:id="loginButton" mnemonicParsing="false" onAction="#onLoginClick" prefWidth="300.0" styleClass="btn-black" text="Sign In" />
            <Label styleClass="text-muted" text="Forgot your password?" />
         </children>
      </VBox>
   </children>
</AnchorPane>
